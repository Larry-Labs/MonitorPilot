{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MonitorPilot",
  "version": "0.1.0",
  "identifier": "com.monitorpilot.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MonitorPilot",
        "label": "main",
        "width": 720,
        "height": 520,
        "minWidth": 380,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "nsis"],
    "externalBin": ["binaries/m1ddc"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Monitor Input Source Switcher",
    "longDescription": "Cross-platform monitor input source switcher using DDC/CI protocol",
    "category": "Utility",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
